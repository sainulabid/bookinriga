# ─────────────────────────────────────────────────────────────
# LuxeStay configuration
# Rename this file to ".env" and fill in your keys.
# Leave any line blank/removed to run that feature in DEV MODE.
# ─────────────────────────────────────────────────────────────

# Flask secret (any random string)
SECRET_KEY=please-change-this-to-a-random-string

# ── Stripe (card payments) ──
# Get test keys free at https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=

# ── Gmail (Email OTP) ──
# Use a Gmail address + an App Password: https://myaccount.google.com/apppasswords
GMAIL_ADDRESS=
GMAIL_APP_PASSWORD=

# ── Google Sign-In ("Continue with Google") ──
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://127.0.0.1:5000/login/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
